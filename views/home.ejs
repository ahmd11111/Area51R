<%- include('partials/header') %>

<!-- Hero Section -->
<section class="hero">
  <div class="hero-content">
    <h1 class="hero-title"><%= typeof settings !== 'undefined' && settings.heroTitle ? settings.heroTitle : t('home.heroTitle') %></h1>
    <p class="hero-subtitle"><%= typeof settings !== 'undefined' && settings.heroSubtitle ? settings.heroSubtitle : t('home.heroSubtitle') %></p>
    <div class="hero-buttons">
      <a href="/store" class="btn btn-primary">
        <i class="fas fa-store"></i> <%= t('home.shopNow') %>
      </a>
      <a href="/rules" class="btn btn-secondary">
        <i class="fas fa-info-circle"></i> <%= t('home.learnMore') %>
      </a>
    </div>
  </div>
  <div class="hero-overlay"></div>
</section>

<!-- Features Section -->
<section class="features">
  <div class="container">
    <h2 class="section-title"><%= t('home.featuresTitle') %></h2>
    <div class="features-grid">
      <div class="feature-card">
        <div class="feature-icon">
          <i class="fas fa-shipping-fast"></i>
        </div>
        <h3><%= t('home.fastShipping') %></h3>
        <p><%= t('home.fastShippingDesc') %></p>
      </div>
      
      <div class="feature-card">
        <div class="feature-icon">
          <i class="fas fa-shield-alt"></i>
        </div>
        <h3><%= t('home.securePayments') %></h3>
        <p><%= t('home.securePaymentsDesc') %></p>
      </div>
      
      <div class="feature-card">
        <div class="feature-icon">
          <i class="fas fa-undo"></i>
        </div>
        <h3><%= t('home.easyReturns') %></h3>
        <p><%= t('home.easyReturnsDesc') %></p>
      </div>
      
      <div class="feature-card">
        <div class="feature-icon">
          <i class="fas fa-headset"></i>
        </div>
        <h3><%= t('home.support24') %></h3>
        <p><%= t('home.support24Desc') %></p>
      </div>
    </div>
  </div>
</section>

<!-- Categories Section -->
<section class="categories">
  <div class="container">
    <h2 class="section-title"><%= t('home.categoriesTitle') %></h2>
    <div class="categories-grid">
      <a href="/store" class="category-card">
        <i class="fas fa-laptop"></i>
        <span><%= t('home.electronics') %></span>
      </a>
      <a href="/store" class="category-card">
        <i class="fas fa-gamepad"></i>
        <span><%= t('home.gaming') %></span>
      </a>
      <a href="/store" class="category-card">
        <i class="fas fa-mobile-alt"></i>
        <span><%= t('home.accessories') %></span>
      </a>
      <a href="/store" class="category-card">
        <i class="fas fa-clock"></i>
        <span><%= t('home.wearables') %></span>
      </a>
    </div>
  </div>
</section>

<!-- CTA Section -->
<section class="cta">
  <div class="container">
    <h2><%= t('home.ctaTitle') %></h2>
    <p><%= t('home.ctaDesc') %></p>
    <a href="/store" class="btn btn-primary">
      <i class="fas fa-store"></i> <%= t('home.browseStore') %>
    </a>
  </div>
</section>

<%- include('partials/footer') %>