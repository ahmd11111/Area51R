<%- include('partials/header') %>

<!-- Login Section -->
<section class="auth-section">
  <div class="auth-container">
    <div class="auth-card">
      <div class="auth-header">
        <div class="auth-logo">
          <span class="logo-icon">✕</span>
          <span class="logo-text">X5</span>
        </div>
        <h2><%= t('auth.loginTitle') %></h2>
        <p><%= t('auth.loginSubtitle') %></p>
      </div>
      
      <% if (typeof error !== 'undefined' && error) { %>
        <div class="alert alert-error">
          <i class="fas fa-exclamation-circle"></i>
          <%= error %>
        </div>
      <% } %>
      
      <form action="/login" method="POST" class="auth-form">
        <div class="form-group">
          <label for="email">
            <i class="fas fa-envelope"></i> <%= t('auth.email') %>
          </label>
          <input type="email" id="email" name="email" required 
            placeholder="Enter your email">
        </div>
        
        <div class="form-group">
          <label for="password">
            <i class="fas fa-lock"></i> <%= t('auth.password') %>
          </label>
          <input type="password" id="password" name="password" required 
            placeholder="Enter your password">
        </div>
        
        <!-- Discord Username Field - Required for digital product delivery -->
        <div class="form-group">
          <label for="discordUsername">
            <i class="fab fa-discord"></i> <%= t('auth.discordUsername') %> <span class="required">*</span>
          </label>
          <input type="text" id="discordUsername" name="discordUsername" 
            placeholder="Enter your Discord username" required
            title="Required for instant digital delivery">
        </div>

        <!-- Remember Me Checkbox -->
        <div class="form-group checkbox-group" style="display: flex; align-items: center; margin-bottom: 15px;">
          <input type="checkbox" id="rememberMe" name="rememberMe" value="on" style="width: auto; margin-left: 10px;">
          <label for="rememberMe" style="margin-bottom: 0; cursor: pointer;">
            تذكرني (Keep me logged in for 30 days)
          </label>
        </div>
        
        <button type="submit" class="btn btn-primary btn-block">
          <i class="fas fa-sign-in-alt"></i> <%= t('auth.loginBtn') %>
        </button>
      </form>
      
      <div class="auth-footer">
        <p><%= t('auth.noAccount') %> <a href="/register"><%= t('auth.registerLink') %></a></p>
      </div>
    </div>
  </div>
</section>

<%- include('partials/footer') %>