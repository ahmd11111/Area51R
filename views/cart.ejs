<%- include('partials/header') %>

<!-- Cart Section -->
<section class="cart-section" style="padding: 40px 0; background-color: #121212; min-height: 80vh;">
  <div class="container" style="max-width: 1200px; margin: 0 auto; padding: 0 20px;">
    <h1 style="text-align: center; color: #fff; margin-bottom: 30px; font-size: 2.5rem;">
      <i class="fas fa-shopping-cart" style="color: #ff3333;"></i> <%= t('cart.title') %>
    </h1>
    
    <% if (cart && cart.length > 0) { %>
      <div class="cart-container" style="display: flex; flex-wrap: wrap; gap: 30px; justify-content: space-between;">
        
        <!-- Cart Items List -->
        <div class="cart-items" style="flex: 2; min-width: 300px;">
          <% cart.forEach(function(item) { %>
            <div class="cart-item" style="display: flex; align-items: center; background: #1e1e1e; border-radius: 10px; padding: 15px; margin-bottom: 15px; box-shadow: 0 4px 6px rgba(0,0,0,0.3);">
              <div class="cart-item-image" style="width: 80px; height: 80px; flex-shrink: 0; margin-left: 15px;">
                <img src="<%= item.image %>" alt="<%= item.name %>" 
                     style="width: 100%; height: 100%; object-fit: cover; border-radius: 8px;" 
                     onerror="this.src='https://images.unsplash.com/photo-1523275335684-37898b6baf30?w=400'">
              </div>
              <div class="cart-item-details" style="flex-grow: 1;">
                <h3 style="color: #fff; margin: 0 0 5px 0; font-size: 1.1rem;"><%= item.name %></h3>
                <p class="item-price" style="color: #aaa; margin: 0; font-size: 0.9rem;">$<%= item.price.toFixed(2) %></p>
                <div class="quantity-controls" style="margin-top: 5px; color: #888; font-size: 0.85rem;">
                  <span><%= t('cart.quantity') %>: <strong style="color: #fff;"><%= item.quantity %></strong></span>
                </div>
              </div>
              <div class="cart-item-total" style="text-align: left; min-width: 120px;">
                <span class="total-price" style="display: block; color: #44ff44; font-weight: bold; font-size: 1.1rem; margin-bottom: 10px;">
                  $<%= (item.price * item.quantity).toFixed(2) %>
                </span>
                <form action="/cart/remove" method="POST" class="remove-form">
                  <input type="hidden" name="productId" value="<%= item.productId %>">
                  <button type="submit" class="btn btn-remove" style="background: transparent; border: 1px solid #ff4444; color: #ff4444; padding: 5px 10px; border-radius: 5px; cursor: pointer; font-size: 0.8rem; transition: all 0.3s;">
                    <i class="fas fa-trash"></i> <%= t('cart.remove') %>
                  </button>
                </form>
              </div>
            </div>
          <% }); %>
        </div>
        
        <!-- Cart Summary -->
        <div class="cart-summary" style="flex: 1; min-width: 300px; background: #1e1e1e; border-radius: 10px; padding: 25px; height: fit-content; box-shadow: 0 4px 6px rgba(0,0,0,0.3);">
          <h2 style="color: #fff; margin-top: 0; border-bottom: 1px solid #333; padding-bottom: 15px; font-size: 1.5rem;">
            <%= t('cart.orderSummary') %>
          </h2>
          
          <!-- Promo Code Section -->
          <div class="promo-section" style="margin-bottom: 20px; padding: 15px; background: #2a2a2a; border-radius: 8px; border: 1px dashed #444;">
            <label for="promoInput" style="display: block; margin-bottom: 8px; font-weight: bold; color: #ddd; font-size: 0.9rem;">
              <i class="fas fa-tag" style="color: #ffcc00;"></i> كود الخصم (Promo Code)
            </label>
            <div style="display: flex; gap: 10px;">
              <input type="text" id="promoInput" placeholder="أدخل الكود هنا (مثال: Area51)" 
                     style="flex: 1; padding: 10px; border-radius: 4px; border: 1px solid #444; background: #121212; color: white; outline: none;">
              <button type="button" id="applyPromoBtn" class="btn btn-secondary" style="padding: 10px 15px; background: #333; color: #fff; border: none; border-radius: 4px; cursor: pointer; transition: background 0.3s;">
                تطبيق
              </button>
            </div>
            <% if (promoError) { %>
              <small style="color: #ff4444; display: block; margin-top: 5px; font-size: 0.85rem;"><%= promoError %></small>
            <% } %>
            <% if (appliedCoupon) { %>
              <small style="color: #44ff44; display: block; margin-top: 5px; font-size: 0.85rem;">
                ✅ تم تطبيق الكود: <strong><%= appliedCoupon.code %></strong> (<%= appliedCoupon.percent %>% خصم)
              </small>
            <% } %>
          </div>

          <div class="summary-details">
            <div class="summary-row" style="display: flex; justify-content: space-between; margin-bottom: 10px; color: #ccc;">
              <span>المجموع الفرعي</span>
              <span>$<%= subtotal.toFixed(2) %></span>
            </div>
            
            <!-- Discount Value Row -->
            <div class="summary-row" style="display: flex; justify-content: space-between; margin-bottom: 10px; <%= discountAmount > 0 ? 'color: #44ff44;' : 'color: #666;' %>">
              <span>قيمة الخصم</span>
              <span>-$<%= discountAmount.toFixed(2) %></span>
            </div>
            
            <div class="summary-row total" style="display: flex; justify-content: space-between; margin-top: 20px; padding-top: 15px; border-top: 2px solid #333; font-size: 1.4rem; font-weight: bold; color: #fff;">
              <span>الإجمالي النهائي</span>
              <span style="color: #ff3333;">$<%= finalTotal.toFixed(2) %></span>
            </div>
          </div>

          <% if (typeof user !== 'undefined' && user) { %>
            
            <!-- PayPal Button Container - مهم جداً: تأكد من وجود هذا العنصر -->
            <div id="paypal-button-container" style="margin-top: 25px; min-height: 150px;"></div>

            <!-- Load PayPal SDK -->
            <script src="https://www.paypal.com/sdk/js?client-id=<%= PAYPAL_CLIENT_ID %>&currency=USD&intent=capture"></script>
            
            <script>
                // تأكد من أن PayPal محمل قبل التنفيذ
                if (typeof paypal !== 'undefined') {
                    paypal.Buttons({
                        createOrder: function(data, actions) {
                            return fetch('/api/create-paypal-order', {
                                method: 'post',
                                headers: { 'content-type': 'application/json' }
                            }).then(function(res) {
                                return res.json();
                            }).then(function(orderData) {
                                return orderData.id;
                            });
                        },
                        onApprove: function(data, actions) {
                            return fetch('/api/capture-paypal-order', {
                                method: 'post',
                                headers: { 'content-type': 'application/json' },
                                body: JSON.stringify({ orderID: data.orderID })
                            }).then(function(res) {
                                return res.json();
                            }).then(function(details) {
                                if (details.status === 'success') {
                                    alert('تم الدفع بنجاح! رقم الطلب: ' + details.orderId);
                                    window.location.href = '/order-success?orderId=' + details.orderId;
                                } else {
                                    alert('حدث خطأ أثناء معالجة الدفع.');
                                }
                            });
                        },
                        onError: function(err) {
                            console.error('PayPal Error:', err);
                            alert('حدث خطأ في نظام الدفع. يرجى المحاولة مرة أخرى.');
                        }
                    }).render('#paypal-button-container');
                } else {
                    console.error('PayPal SDK failed to load.');
                    document.getElementById('paypal-button-container').innerHTML = '<p style="color:red; text-align:center;">خطأ في تحميل نظام الدفع. يرجى تحديث الصفحة.</p>';
                }
            </script>

          <% } else { %>
            <div class="login-prompt" style="text-align: center; margin-top: 20px; padding: 15px; background: #2a2a2a; border-radius: 8px;">
              <p style="color: #ccc; margin-bottom: 10px;">
                <i class="fas fa-lock"></i> يجب تسجيل الدخول لإتمام عملية الدفع
              </p>
              <a href="/login" class="btn btn-primary" style="display: inline-block; background: #ff3333; color: #fff; padding: 10px 20px; text-decoration: none; border-radius: 5px; font-weight: bold;">
                <i class="fas fa-sign-in-alt"></i> سجل دخول الآن
              </a>
            </div>
          <% } %>
          
          <a href="/store" class="btn btn-secondary btn-block" style="display: block; width: 100%; text-align: center; margin-top: 15px; padding: 12px; background: #333; color: #fff; text-decoration: none; border-radius: 5px; transition: background 0.3s;">
            <i class="fas fa-arrow-left"></i> Continue Shopping
          </a>
        </div>
      </div>
    <% } else { %>
      <div class="empty-cart" style="text-align: center; padding: 50px 20px; background: #1e1e1e; border-radius: 10px;">
        <i class="fas fa-shopping-basket" style="font-size: 4rem; color: #444; margin-bottom: 20px;"></i>
        <h2 style="color: #fff; margin-bottom: 10px;">Your Cart is Empty</h2>
        <p style="color: #aaa; margin-bottom: 20px;">Looks like you haven't added any items yet!</p>
        <a href="/store" class="btn btn-primary" style="display: inline-block; background: #ff3333; color: #fff; padding: 12px 25px; text-decoration: none; border-radius: 5px; font-weight: bold;">
          <i class="fas fa-store"></i> Start Shopping
        </a>
      </div>
    <% } %>
  </div>
</section>

<script>
  // JavaScript to handle Promo Code Application
  document.getElementById('applyPromoBtn').addEventListener('click', function() {
    const code = document.getElementById('promoInput').value.trim();
    if (code) {
      window.location.href = '/cart?promo=' + encodeURIComponent(code);
    }
  });
</script>

<%- include('partials/footer') %>
