<%- include('partials/header') %>

<!-- Cart Section -->
<section class="cart-section">
  <div class="container">
    <h1><i class="fas fa-shopping-cart"></i> <%= t('cart.title') %></h1>
    
    <% if (cart && cart.length > 0) { %>
      <div class="cart-container">
        <div class="cart-items">
          <% cart.forEach(function(item) { %>
            <div class="cart-item">
              <div class="cart-item-image">
                <img src="<%= item.image %>" alt="<%= item.name %>" onerror="this.src='https://images.unsplash.com/photo-1523275335684-37898b6baf30?w=400'">
              </div>
              <div class="cart-item-details">
                <h3><%= item.name %></h3>
                <p class="item-price">$<%= item.price.toFixed(2) %></p>
                <div class="quantity-controls">
                  <span><%= t('cart.quantity') %>: <%= item.quantity %></span>
                </div>
              </div>
              <div class="cart-item-total">
                <span class="total-price">$<%= (item.price * item.quantity).toFixed(2) %></span>
                <form action="/cart/remove" method="POST" class="remove-form">
                  <input type="hidden" name="productId" value="<%= item.productId %>">
                  <button type="submit" class="btn btn-remove">
                    <i class="fas fa-trash"></i> <%= t('cart.remove') %>
                  </button>
                </form>
              </div>
            </div>
          <% }); %>
        </div>
        
        <div class="cart-summary">
          <h2><%= t('cart.orderSummary') %></h2>
          <div class="summary-row">
            <span>المجموع</span>
            <span id="subtotal">$<%= total.toFixed(2) %></span>
          </div>
          <div class="summary-row">
            <span>الخصم</span>
            <span id="discountAmount">$0.00</span>
          </div>
          <div class="summary-row">
            <span>الشحن</span>
            <span id="shippingAmount">$<%= total >= 100 ? '0.00' : '9.99' %></span>
          </div>
          <div class="summary-row total">
            <span>الإجمالي بعد الخصم</span>
            <span id="finalTotal">$<%= (total + (total >= 100 ? 0 : 9.99)).toFixed(2) %></span>
          </div>
          <% if (typeof user !== 'undefined' && user) { %>
            <form action="/cart/checkout" method="POST" class="checkout-form" id="checkoutForm">
              <div class="promo-input-group">
                <label for="promoCode">
                  <i class="fas fa-ticket-alt"></i> كود الخصم (برومو كود)
                </label>
                <input type="text" id="promoCode" name="promoCode" placeholder="ادخل كود الخصم إذا وجد">
                <button type="button" class="btn btn-secondary" id="applyCouponBtn">تطبيق</button>
                <small id="promoMsg"></small>
              </div>
              
              <!-- Payment Method Selection -->
              <div class="payment-selection">
                <label><i class="fas fa-wallet"></i> اختر طريقة الدفع</label>
                <div class="payment-options">
                  <label class="payment-option">
                    <input type="radio" name="paymentMethod" value="paypal" checked>
                    <span class="payment-radio"></span>
                    <i class="fab fa-paypal"></i>
                    <span>PayPal</span>
                  </label>
                  <label class="payment-option">
                    <input type="radio" name="paymentMethod" value="card">
                    <span class="payment-radio"></span>
                    <i class="fab fa-cc-visa"></i>
                    <i class="fab fa-cc-mastercard"></i>
                    <span>Credit Card</span>
                  </label>
                  <label class="payment-option">
                    <input type="radio" name="paymentMethod" value="applepay">
                    <span class="payment-radio"></span>
                    <i class="fab fa-apple"></i>
                    <span>Apple Pay</span>
                  </label>
                  <label class="payment-option">
                    <input type="radio" name="paymentMethod" value="binance">
                    <span class="payment-radio"></span>
                    <i class="fab fa-bitcoin"></i>
                    <span>Binance Pay</span>
                  </label>
                </div>
              </div>
              
              <!-- Binance Payment Details (Hidden by default) -->
              <div class="binance-details" id="binanceDetails" style="display: none;">
                <div class="binance-info">
                  <h4><i class="fab fa-bitcoin"></i> الدفع عبر Binance</h4>
                  <p>ارسل المبلغ عبر Binance Pay إلى العنوان التالي:</p>
                  <div class="wallet-address">
                    <code>YOUR_BINANCE_WALLET_ADDRESS_HERE</code>
                    <button type="button" class="copy-btn" onclick="copyWallet()">
                      <i class="fas fa-copy"></i> نسخ
                    </button>
                  </div>
                  <p class="binance-note">أو يمكنك مسح QR Code:</p>
                  <div class="qr-placeholder">
                    <i class="fas fa-qrcode"></i>
                    <span>QR Code</span>
                  </div>
                </div>
                <div class="txid-input">
                  <label for="txid">
                    <i class="fas fa-hashtag"></i> رقم المعاملة (TXID)
                  </label>
                  <input type="text" id="txid" name="txid" placeholder="أدخل TXID بعد إتمام الدفع">
                  <small>ستجد TXID في تاريخ المعاملة في تطبيق Binance</small>
                </div>
              </div>
              
              <button type="submit" class="btn btn-primary btn-block pay-now-btn">
                <i class="fas fa-credit-card"></i> <span>ادفع الآن</span>
              </button>
            </form>
          <% } else { %>
            <div class="login-prompt">
              <p><i class="fas fa-info-circle"></i> <%= t('cart.loginToCheckout') %></p>
              <a href="/login" class="btn btn-primary">
                <i class="fas fa-sign-in-alt"></i> Login
              </a>
            </div>
          <% } %>
          
          <a href="/store" class="btn btn-secondary btn-block">
            <i class="fas fa-arrow-left"></i> Continue Shopping
          </a>
        </div>
      </div>
    <% } else { %>
      <div class="empty-cart">
        <i class="fas fa-shopping-basket"></i>
        <h2>Your Cart is Empty</h2>
        <p>Looks like you haven't added any items yet!</p>
        <a href="/store" class="btn btn-primary">
          <i class="fas fa-store"></i> Start Shopping
        </a>
      </div>
    <% } %>
  </div>
</section>

<style>
.discord-input-group {
  margin-bottom: 20px;
  text-align: right;
}
.discord-input-group label {
  display: block;
  color: #ff3333;
  font-weight: 600;
  margin-bottom: 8px;
  font-size: 14px;
}
.discord-input-group input {
  width: 100%;
  padding: 12px 15px;
  border: 2px solid #333;
  border-radius: 8px;
  background: #0d0d0d;
  color: #fff;
  font-size: 14px;
  box-sizing: border-box;
  transition: all 0.3s ease;
}
.discord-input-group input:focus {
  outline: none;
  border-color: #ff3333;
  box-shadow: 0 0 10px rgba(255, 51, 51, 0.3);
}
.discord-input-group small {
  display: block;
  color: #888;
  margin-top: 5px;
  font-size: 12px;
}
</style>

<%- include('partials/footer') %>