<%- include('partials/header') %>

<!-- Leaderboard Header -->
<section class="page-header">
  <div class="container">
    <h1><%= t('leaderboard.title') %></h1>
    <p><%= t('leaderboard.subtitle') %></p>
  </div>
</section>

<!-- Leaderboard Content -->
<section class="leaderboard-content">
  <div class="container">
    <div class="leaderboard-card">
      <div class="leaderboard-header">
        <i class="fas fa-trophy"></i>
        <h2><%= t('leaderboard.topBuyers') %></h2>
      </div>
      
      <% if (leaderboard && leaderboard.length > 0) { %>
        <div class="leaderboard-table">
          <div class="leaderboard-row header">
            <div class="rank">#</div>
            <div class="buyer">Buyer</div>
            <div class="orders"><%= t('leaderboard.orders') %></div>
            <div class="spent"><%= t('leaderboard.totalSpent') %></div>
          </div>
          
          <% leaderboard.forEach(function(buyer, index) { %>
            <div class="leaderboard-row <%= index < 3 ? 'top-' + (index + 1) : '' %>">
              <div class="rank">
                <% if (index === 0) { %>
                  <i class="fas fa-crown gold"></i>
                <% } else if (index === 1) { %>
                  <i class="fas fa-medal silver"></i>
                <% } else if (index === 2) { %>
                  <i class="fas fa-medal bronze"></i>
                <% } else { %>
                  <span><%= index + 1 %></span>
                <% } %>
              </div>
              <div class="buyer">
                <div class="buyer-avatar">
                  <i class="fas fa-user"></i>
                </div>
                <span class="buyer-email"><%= buyer.email %></span>
              </div>
              <div class="orders">
                <span class="order-count"><%= buyer.totalOrders %></span>
              </div>
              <div class="spent">
                <span class="total-amount">$<%= buyer.totalSpent.toFixed(2) %></span>
              </div>
            </div>
          <% }); %>
        </div>
      <% } else { %>
        <div class="no-leaderboard">
          <i class="fas fa-chart-line"></i>
          <h3>No Orders Yet</h3>
          <p>Be the first to place an order and climb the leaderboard!</p>
          <a href="/store" class="btn btn-primary">
            <i class="fas fa-store"></i> Start Shopping
          </a>
        </div>
      <% } %>
    </div>
    
    <div class="leaderboard-info">
      <div class="info-card">
        <i class="fas fa-star"></i>
        <h3>How It Works</h3>
        <p>The more you shop, the higher you climb on the leaderboard!</p>
      </div>
      <div class="info-card">
        <i class="fas fa-gift"></i>
        <h3>Earn Rewards</h3>
        <p>Top buyers may receive exclusive discounts and special offers.</p>
      </div>
    </div>
  </div>
</section>

<%- include('partials/footer') %>