<%- include('partials/header') %>

<!-- Store Header -->
<section class="store-header">
  <div class="container">
    <h1><%= t('store.title') %></h1>
    <p><%= t('store.subtitle') %></p>
    
    <% if (typeof isAdmin !== 'undefined' && isAdmin) { %>
      <a href="/admin/products/new" class="btn btn-admin">
        <i class="fas fa-plus"></i> <%= t('store.newProduct') %>
      </a>
    <% } %>
  </div>
</section>

<!-- Category Filter Bar -->
<section class="category-filter">
  <div class="container">
    <div class="filter-buttons">
      <button class="filter-btn active" data-category="all">
        <i class="fas fa-th"></i> <%= t('categories.all') || 'الكل' %>
      </button>
      <button class="filter-btn" data-category="سيارات">
        <i class="fas fa-car"></i> <%= t('categories.cars') || 'سيارات' %>
      </button>
      <button class="filter-btn" data-category="عصابات">
        <i class="fas fa-users"></i> <%= t('categories.gangs') || 'عصابات' %>
      </button>
      <button class="filter-btn" data-category="متاجر ومحلات">
        <i class="fas fa-store"></i> <%= t('categories.stores') || 'متاجر ومحلات' %>
      </button>
      <button class="filter-btn" data-category="شخصيات">
        <i class="fas fa-user"></i> <%= t('categories.characters') || 'شخصيات' %>
      </button>
    </div>
  </div>
</section>

<!-- Products Grid -->
<section class="products-section">
  <div class="container">
    <% if (products && products.length > 0) { %>
      <div class="products-grid" id="productsGrid">
        <% products.forEach(function(product) { %>
          <div class="product-card" data-category="<%= product.category %>">
            <div class="product-image">
              <img src="<%= product.image %>" alt="<%= product.name %>" onerror="this.src='https://images.unsplash.com/photo-1523275335684-37898b6baf30?w=400'">
              <div class="product-overlay">
                <form action="/cart/add" method="POST" class="add-to-cart-form">
                  <input type="hidden" name="productId" value="<%= product.id %>">
                  <input type="hidden" name="name" value="<%= product.name %>">
                  <input type="hidden" name="price" value="<%= product.price %>">
                  <input type="hidden" name="image" value="<%= product.image %>">
                  <button type="submit" class="btn btn-add-cart">
                    <i class="fas fa-cart-plus"></i> <%= t('store.addToCart') %>
                  </button>
                </form>
              </div>
            </div>
            <div class="product-info">
              <span class="product-category"><%= product.category || t('categories.general') %></span>
              <h3 class="product-name"><%= product.name %></h3>
              <p class="product-description"><%= product.description %></p>
              <div class="product-footer">
                <span class="product-price">$<%= product.price.toFixed(2) %></span>
                <% if (typeof isAdmin !== 'undefined' && isAdmin) { %>
                  <a href="/edit/<%= product.id %>" class="btn btn-edit">
                    <i class="fas fa-edit"></i> <%= t('store.edit') %>
                  </a>
                <% } %>
              </div>
            </div>
          </div>
        <% }); %>
      </div>
    <% } else { %>
      <div class="no-products">
        <i class="fas fa-box-open"></i>
        <h2>No Products Available</h2>
        <p>Check back soon for new products!</p>
      </div>
    <% } %>
  </div>
</section>

<style>
.category-filter {
  background: linear-gradient(180deg, #1a0a0a 0%, #0d0d0d 100%);
  padding: 20px 0;
  border-bottom: 2px solid #8b0000;
}
.filter-buttons {
  display: flex;
  justify-content: center;
  gap: 15px;
  flex-wrap: wrap;
}
.filter-btn {
  background: #1a1a1a;
  border: 2px solid #333;
  color: #ccc;
  padding: 12px 24px;
  border-radius: 8px;
  cursor: pointer;
  font-size: 14px;
  font-weight: 600;
  transition: all 0.3s ease;
  display: flex;
  align-items: center;
  gap: 8px;
}
.filter-btn:hover {
  border-color: #ff3333;
  color: #ff3333;
  box-shadow: 0 0 15px rgba(255, 51, 51, 0.4);
}
.filter-btn.active {
  background: linear-gradient(135deg, #8b0000, #cc0000);
  border-color: #ff3333;
  color: #fff;
  box-shadow: 0 0 20px rgba(255, 51, 51, 0.5);
}
.product-card.hidden {
  display: none;
}
</style>

<script>
document.addEventListener('DOMContentLoaded', function() {
  const filterBtns = document.querySelectorAll('.filter-btn');
  const products = document.querySelectorAll('.product-card');
  
  filterBtns.forEach(btn => {
    btn.addEventListener('click', function() {
      const category = this.getAttribute('data-category');
      
      // Update active button
      filterBtns.forEach(b => b.classList.remove('active'));
      this.classList.add('active');
      
      // Filter products
      products.forEach(product => {
        if (category === 'all' || product.getAttribute('data-category') === category) {
          product.classList.remove('hidden');
        } else {
          product.classList.add('hidden');
        }
      });
    });
  });
});
</script>

<%- include('partials/footer') %>