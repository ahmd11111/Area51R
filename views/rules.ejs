<%- include('partials/header') %>

<!-- Rules Header -->
<section class="page-header">
  <div class="container">
    <h1><%= t('rules.title') %></h1>
    <p><%= t('rules.subtitle') %></p>
  </div>
</section>

<!-- Rules Content -->
<section class="rules-content">
  <div class="container">
    <div class="rules-card">
      <div class="rules-header">
        <i class="fas fa-gavel"></i>
        <h2><%= t('rules.storeRules') %></h2>
      </div>
      
      <div class="rules-body">
        <!-- New Arabic Rules -->
        <div class="rule-item">
          <p>يمنع استرجاع او استبدال المنتج</p>
        </div>
        <div class="rule-item">
          <p>في حال سوء استخدام المنتج يتم سحبه ولا يحق لك طلب تعويض</p>
        </div>
        <div class="rule-item">
          <p>المنتجات صالحة لمدة موسم واحد فقط</p>
        </div>
        <div class="rule-item">
          <p>يجب عليك فتح تذكرة في الديسكورد لاستلام طلبك</p>
        </div>
        <div class="rule-item">
          <p>في حال تم تبنيدك من السيرفر يتم سحب المنتج منك</p>
        </div>
        <div class="rule-item">
          <p>يمنع بيع المنتج داخل السيرفر لأي شخص اخر ومن يخالف ذلك يتم سحب المنتج منه</p>
        </div>
        <div class="rule-item">
          <p>جميع المنتجات تشمل سيزون واحد فقط</p>
        </div>
        
        <% if (typeof settings !== 'undefined' && settings.rulesContent) { %>
          <% const rules = settings.rulesContent.split('\n'); %>
          <% rules.forEach(function(rule) { %>
            <% if (rule.trim()) { %>
              <% if (rule.match(/^\d+\./)) { %>
                <div class="rule-item numbered">
                  <p><%= rule %></p>
                </div>
              <% } else { %>
                <p><%= rule %></p>
              <% } %>
            <% } %>
          <% }); %>
        <% } else { %>
          <div class="rule-item">
            <h3>1. Order Policy</h3>
            <p>All orders are final once placed. Please ensure your order details are correct before checkout.</p>
          </div>
          
          <div class="rule-item">
            <h3>2. Return Policy</h3>
            <p>We offer a 30-day return policy on all products. Items must be in original condition.</p>
          </div>      
          
          <div class="rule-item">
            <h3>4. Support</h3>
            <p>Our support team is available 24/7 to assist you with any questions or concerns.</p>
          </div>
        <% } %>
      </div>
    </div>
    
    <div class="support-card">
      <h3><i class="fas fa-headset"></i> Need Help?</h3>
      <p>Contact our support team for any questions</p>
      <div class="support-options">
        <a href="mailto:<%= typeof settings !== 'undefined' && settings.supportEmail ? settings.supportEmail : 'support@x5.com' %>" class="support-option">
          <i class="fas fa-envelope"></i>
          <span><%= typeof settings !== 'undefined' && settings.supportEmail ? settings.supportEmail : 'support@x5.com' %></span>
        </a>
        <a href="tel:<%= typeof settings !== 'undefined' && settings.supportPhone ? settings.supportPhone : '+1234567890' %>" class="support-option">
          <i class="fas fa-phone"></i>
          <span><%= typeof settings !== 'undefined' && settings.supportPhone ? settings.supportPhone : '+1234567890' %></span>
        </a>
      </div>
    </div>
  </div>
</section>

<%- include('partials/footer') %>