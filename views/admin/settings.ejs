<%- include('../partials/header') %>

<!-- Admin Settings Section -->
<section class="admin-section">
  <div class="container">
    <div class="form-container">
      <div class="form-header">
        <h1><i class="fas fa-sliders-h"></i> <%= t('admin.settings') %></h1>
        <p>Edit your site content and information</p>
      </div>
      
      <form action="/admin/settings" method="POST" class="settings-form">
        <div class="settings-section">
          <h3><i class="fas fa-globe"></i> <%= t('admin.generalSettings') %></h3>
          
          <div class="form-group">
            <label for="siteName">
              <i class="fas fa-heading"></i> <%= t('admin.siteName') %>
            </label>
            <input type="text" id="siteName" name="siteName" 
              value="<%= typeof settings !== 'undefined' && settings.siteName ? settings.siteName : 'X5 Store' %>"
              placeholder="Enter site name">
          </div>
          
          <div class="form-group">
            <label for="siteDescription">
              <i class="fas fa-align-left"></i> <%= t('admin.siteDescription') %>
            </label>
            <textarea id="siteDescription" name="siteDescription" rows="2" 
              placeholder="Enter site description"><%= typeof settings !== 'undefined' && settings.siteDescription ? settings.siteDescription : '' %></textarea>
          </div>
        </div>
        
        <div class="settings-section">
          <h3><i class="fas fa-home"></i> <%= t('admin.homePage') %></h3>
          
          <div class="form-group">
            <label for="heroTitle">
              <i class="fas fa-title"></i> <%= t('admin.heroTitle') %>
            </label>
            <input type="text" id="heroTitle" name="heroTitle" 
              value="<%= typeof settings !== 'undefined' && settings.heroTitle ? settings.heroTitle : '' %>"
              placeholder="Welcome to X5">
          </div>
          
          <div class="form-group">
            <label for="heroSubtitle">
              <i class="fas fa-subtitle"></i> <%= t('admin.heroSubtitle') %>
            </label>
            <input type="text" id="heroSubtitle" name="heroSubtitle" 
              value="<%= typeof settings !== 'undefined' && settings.heroSubtitle ? settings.heroSubtitle : '' %>"
              placeholder="Discover amazing products...">
          </div>
        </div>
        
        <div class="settings-section">
          <h3><i class="fas fa-gavel"></i> Rules Page</h3>
          
          <div class="form-group">
            <label for="rulesContent">
              <i class="fas fa-file-alt"></i> Rules Content
            </label>
            <textarea id="rulesContent" name="rulesContent" rows="8" 
              placeholder="Enter store rules (one per line)">><%= typeof settings !== 'undefined' && settings.rulesContent ? settings.rulesContent : '' %></textarea>
            <small>Separate rules with new lines</small>
          </div>
        </div>
        
        <div class="settings-section">
          <h3><i class="fas fa-headset"></i> Support Information</h3>
          
          <div class="form-row">
            <div class="form-group">
              <label for="supportEmail">
                <i class="fas fa-envelope"></i> Support Email
              </label>
              <input type="email" id="supportEmail" name="supportEmail" 
                value="<%= typeof settings !== 'undefined' && settings.supportEmail ? settings.supportEmail : '' %>"
                placeholder="support@x5.com">
            </div>
            
            <div class="form-group">
              <label for="supportPhone">
                <i class="fas fa-phone"></i> Support Phone
              </label>
              <input type="text" id="supportPhone" name="supportPhone" 
                value="<%= typeof settings !== 'undefined' && settings.supportPhone ? settings.supportPhone : '' %>"
                placeholder="+1234567890">
            </div>
          </div>
        </div>
        
        <div class="form-actions">
          <button type="submit" class="btn btn-primary">
            <i class="fas fa-save"></i> Save Settings
          </button>
          <a href="/" class="btn btn-secondary">
            <i class="fas fa-home"></i> Back to Home
          </a>
        </div>
      </form>
    </div>
  </div>
</section>

<%- include('../partials/footer') %>