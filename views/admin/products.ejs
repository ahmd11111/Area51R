<%- include('../partials/header') %>

<!-- Admin Products Page -->
<section class="admin-section">
  <div class="admin-header">
    <h1><i class="fas fa-box"></i> إدارة المنتجات</h1>
    <p>عرض وإدارة جميع المنتجات في المتجر</p>
  </div>
  
  <div class="admin-actions">
    <a href="/admin" class="btn btn-secondary">
      <i class="fas fa-arrow-right"></i> العودة للوحة التحكم
    </a>
    <a href="/admin/products/new" class="btn btn-primary">
      <i class="fas fa-plus"></i> إضافة منتج جديد
    </a>
  </div>
  
  <div class="admin-content">
    <% if (products && products.length > 0) { %>
      <div class="admin-table-container">
        <table class="admin-table">
          <thead>
            <tr>
              <th>الصورة</th>
              <th>اسم المنتج</th>
              <th>السعر</th>
              <th>الفئة</th>
              <th>الإجراءات</th>
            </tr>
          </thead>
          <tbody>
            <% products.forEach(function(product) { %>
              <tr>
                <td>
                  <img src="<%= product.image %>" alt="<%= product.name %>" class="table-image" onerror="this.src='https://images.unsplash.com/photo-1523275335684-37898b6baf30?w=400'">
                </td>
                <td><%= product.name %></td>
                <td class="product-price"><%= product.price %> دولار</td>
                <td><span class="badge"><%= product.category %></span></td>
                <td class="action-buttons">
                  <a href="/edit/<%= product.id %>" class="btn-edit">
                    <i class="fas fa-edit"></i> تعديل
                  </a>
                  <form method="POST" action="/admin/products/delete/<%= product.id %>" class="delete-form">
                    <button type="submit" class="btn-delete" onclick="return confirm('هل أنت متأكد من حذف هذا المنتج؟');">
                      <i class="fas fa-trash"></i> حذف
                    </button>
                  </form>
                </td>
              </tr>
            <% }); %>
          </tbody>
        </table>
      </div>
    <% } else { %>
      <div class="no-data">
        <i class="fas fa-box-open"></i>
        <h2>لا توجد منتجات</h2>
        <p>لم تقم بإضافة أي منتجات بعد. ابدأ بإضافة منتج جديد!</p>
        <a href="/admin/products/new" class="btn btn-primary">
          <i class="fas fa-plus"></i> إضافة أول منتج
        </a>
      </div>
    <% } %>
  </div>
</section>

<%- include('../partials/footer') %>