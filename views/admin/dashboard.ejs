<%- include('../partials/header') %>

<!-- Admin Dashboard -->
<section class="admin-section">
  <div class="container">
    <div class="admin-header">
      <h1><i class="fas fa-cogs"></i> Area 51 - لوحة التحكم</h1>
      <p>إدارة متجرك</p>
    </div>
    
    <div class="admin-nav">
      <a href="/admin" class="admin-nav-item <%= typeof title !== 'undefined' && title === 'Admin Dashboard' ? 'active' : '' %>">
        <i class="fas fa-tachometer-alt"></i>
        <span>لوحة التحكم</span>
      </a>
      <a href="/admin/products" class="admin-nav-item <%= typeof title !== 'undefined' && title === 'Manage Products' ? 'active' : '' %>">
        <i class="fas fa-box"></i>
        <span>المنتجات</span>
      </a>
      <a href="/admin/orders" class="admin-nav-item <%= typeof title !== 'undefined' && title === 'Manage Orders' ? 'active' : '' %>">
        <i class="fas fa-shopping-bag"></i>
        <span>الطلبات</span>
      </a>
      <a href="/admin/coupons" class="admin-nav-item <%= typeof title !== 'undefined' && title === 'Manage Coupons' ? 'active' : '' %>">
        <i class="fas fa-ticket-alt"></i>
        <span>الكوبونات</span>
      </a>
      <a href="/" class="admin-nav-item">
        <i class="fas fa-arrow-left"></i>
        <span>العودة للمتجر</span>
      </a>
    </div>
    
    <!-- Stats Cards -->
    <div class="admin-stats">
      <div class="stat-card">
        <div class="stat-icon">
          <i class="fas fa-box"></i>
        </div>
        <div class="stat-info">
          <h3><%= products ? products.length : 0 %></h3>
          <p><%= t('admin.products') %></p>
        </div>
      </div>
      
      <div class="stat-card">
        <div class="stat-icon">
          <i class="fas fa-shopping-bag"></i>
        </div>
        <div class="stat-info">
          <h3><%= orders ? orders.length : 0 %></h3>
          <p><%= t('admin.orders') %></p>
        </div>
      </div>
      
      <div class="stat-card">
        <div class="stat-icon">
          <i class="fas fa-users"></i>
        </div>
        <div class="stat-info">
          <h3><%= orders ? orders.filter(o => o.status === 'Pending').length : 0 %></h3>
          <p><%= t('status.pending') %></p>
        </div>
      </div>
      
      <div class="stat-card">
        <div class="stat-icon">
          <i class="fas fa-dollar-sign"></i>
        </div>
        <div class="stat-info">
          <h3>$<%= orders ? orders.reduce((sum, o) => sum + (o.total || 0), 0).toFixed(2) : '0.00' %></h3>
          <p>Total Revenue</p>
        </div>
      </div>
    </div>
    
    <!-- Quick Actions -->
    <div class="admin-quick-actions">
      <h2>Quick Actions</h2>
      <div class="action-buttons-grid">
        <a href="/admin/products/new" class="quick-action-btn">
          <i class="fas fa-plus-circle"></i>
          <span><%= t('admin.addProduct') %></span>
        </a>
        <a href="/admin/orders" class="quick-action-btn">
          <i class="fas fa-list"></i>
          <span><%= t('admin.orders') %></span>
        </a>
        <a href="/admin/settings" class="quick-action-btn">
          <i class="fas fa-cog"></i>
          <span><%= t('admin.settings') %></span>
        </a>
        <a href="/admin/edit-text" class="quick-action-btn">
          <i class="fas fa-pen-alt"></i>
          <span><%= t('admin.editSiteText') %></span>
        </a>
      </div>
    </div>
    
    <!-- Delete All Products - Bulk Action -->
    <div class="admin-danger-zone">
      <h2><i class="fas fa-exclamation-triangle"></i> Danger Zone</h2>
      <div class="danger-action">
        <div class="danger-info">
          <h3>حذف جميع المنتجات</h3>
          <p>This will permanently delete all <%= products ? products.length : 0 %> products from the database.</p>
        </div>
        <form method="POST" action="/admin/products/delete-all" onsubmit="return confirm('هل أنت متأكد من حذف جميع المنتجات؟ هذا الإجراء لا يمكن التراجع عنه.');">
          <button type="submit" class="btn btn-danger">
            <i class="fas fa-trash-alt"></i> حذف جميع المنتجات
          </button>
        </form>
      </div>
    </div>
  </div>
</section>

<%- include('../partials/footer') %>