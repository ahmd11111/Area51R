<!DOCTYPE html>
<html lang="<%= typeof lang !== 'undefined' ? lang : 'en' %>">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= typeof title !== 'undefined' ? title : 'X5 Store' %></title>
  <link rel="stylesheet" href="/css/style.css">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@300;400;600;700;800&family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <style>
    body { direction: <%= typeof lang !== 'undefined' && lang === 'ar' ? 'rtl' : 'ltr' %>; }
  </style>
</head>
<body>
  <!-- Navigation Bar -->
  <nav class="navbar">
    <div class="nav-container">
      <a href="/" class="logo">
        <span class="logo-icon">✕</span>
        <span class="logo-text">X5</span>
      </a>
      
      <ul class="nav-links">
        <li><a href="/" class="<%= typeof title !== 'undefined' && title === 'Home' ? 'active' : '' %>">
          <i class="fas fa-home"></i> <%= t('nav.home') %>
        </a></li>
        <li><a href="/store" class="<%= typeof title !== 'undefined' && title === 'Store' ? 'active' : '' %>">
          <i class="fas fa-store"></i> <%= t('nav.store') %>
        </a></li>
        <li><a href="/rules" class="<%= typeof title !== 'undefined' && title === 'Rules' ? 'active' : '' %>">
          <i class="fas fa-gavel"></i> <%= t('nav.rules') %>
        </a></li>
        <li><a href="/leaderboard" class="<%= typeof title !== 'undefined' && title === 'Leaderboard' ? 'active' : '' %>">
          <i class="fas fa-trophy"></i> <%= t('nav.leaderboard') %>
        </a></li>
        <li><a href="mailto:<%= typeof settings !== 'undefined' && settings.supportEmail ? settings.supportEmail : 'support@x5.com' %>" class="support-btn">
          <i class="fas fa-headset"></i> <%= t('nav.support') %>
        </a></li>
      </ul>
      
      <div class="nav-right">
        <!-- Language Switcher -->
        <div class="language-switcher">
          <button class="lang-btn <%= typeof lang !== 'undefined' && lang === 'en' ? 'active' : '' %>" onclick="location.href='/lang/en'">
            <i class="fas fa-globe"></i> EN
          </button>
          <button class="lang-btn <%= typeof lang !== 'undefined' && lang === 'ar' ? 'active' : '' %>" onclick="location.href='/lang/ar'">
            <i class="fas fa-globe"></i> العربية
          </button>
        </div>
        
        <div class="nav-auth">
          <% if (typeof user !== 'undefined' && user) { %>
            <span class="user-greeting"><%= typeof user.name !== 'undefined' ? user.name : user.email %></span>
            <% if (typeof isAdmin !== 'undefined' && isAdmin) { %>
              <a href="/admin" class="admin-link">
                <i class="fas fa-cog"></i> <%= t('nav.admin') %>
              </a>
            <% } %>
            <a href="/logout" class="auth-btn logout"><%= t('nav.logout') %></a>
          <% } else { %>
            <a href="/login" class="auth-btn"><%= t('nav.login') %></a>
            <a href="/register" class="auth-btn register"><%= t('nav.register') %></a>
          <% } %>
        </div>
      </div>
      
      <button class="mobile-menu-btn">
        <i class="fas fa-bars"></i>
      </button>
    </div>
  </nav>

  <!-- Floating Cart Button -->
  <a href="/cart" class="floating-cart">
    <i class="fas fa-shopping-cart"></i>
    <% if (typeof cart !== 'undefined' && cart.length > 0) { %>
      <span class="cart-count"><%= cart.reduce((sum, item) => sum + item.quantity, 0) %></span>
    <% } %>
  </a>