<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  
  <!-- عنوان الصفحة يتغير ديناميكياً -->
  <title><%= typeof title !== 'undefined' ? title : 'Area 51' %></title>
  
  <!-- أيقونة الموقع (Favicon) - تظهر جنب العنوان في المتصفح -->
  <link rel="icon" type="image/png" href="/logo/Area.png">
  <link rel="icon" type="image/png" sizes="32x32" href="/logo/Area.png">
  <link rel="apple-touch-icon" sizes="180x180" href="/logo/Area.png">
  <link rel="icon" type="image/x-icon" href="/favicon.ico">

  <!-- ملفات التنسيق والخطوط -->
  <link rel="stylesheet" href="/css/style.css">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@300;400;600;700;800&family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  
  <style>
    body { direction: rtl; }
  </style>
</head>
<body>
  <!-- Navigation Bar -->
  <nav class="navbar">
    <div class="nav-container">
      <!-- Right: Brand Logo + Name -->
      <a href="/" class="logo">
        <img src="/Logo/Area.png" alt="Area 51" class="logo-img">
        <span class="logo-text">Area 51</span>
      </a>
      
      <!-- Center: Navigation Links -->
      <ul class="nav-links">
        <li><a href="/" class="<%= typeof title !== 'undefined' && title === 'Home' ? 'active' : '' %>">
          <i class="fas fa-home"></i> الرئيسية
        </a></li>
        <li><a href="/store" class="<%= typeof title !== 'undefined' && title === 'Store' ? 'active' : '' %>">
          <i class="fas fa-store"></i> المتجر
        </a></li>
        <li><a href="/rules" class="<%= typeof title !== 'undefined' && title === 'Rules' ? 'active' : '' %>">
          <i class="fas fa-gavel"></i> القوانين
        </a></li>
        <li><a href="/leaderboard" class="<%= typeof title !== 'undefined' && title === 'Leaderboard' ? 'active' : '' %>">
          <i class="fas fa-trophy"></i> لوحة المتصدرين
        </a></li>
      </ul>
      
      <!-- Left: Auth Buttons -->
      <div class="nav-auth">
        <% if (typeof user !== 'undefined' && user) { %>
          <% if (typeof isAdmin !== 'undefined' && isAdmin) { %>
            <a href="/admin" class="auth-btn admin-btn">
              <i class="fas fa-cog"></i> لوحة الإدارة
            </a>
          <% } %>
          <a href="/logout" class="auth-btn logout">
            <i class="fas fa-sign-out-alt"></i> تسجيل الخروج
          </a>
        <% } else { %>
          <a href="/login" class="auth-btn">
            <i class="fas fa-sign-in-alt"></i> تسجيل الدخول
          </a>
          <a href="/register" class="auth-btn register">
            <i class="fas fa-user-plus"></i> إنشاء حساب
          </a>
        <% } %>
      </div>
      
      <button class="mobile-menu-btn">
        <i class="fas fa-bars"></i>
      </button>
    </div>
  </nav>

  <!-- Floating Cart Button -->
  <a href="/cart" class="floating-cart">
    <i class="fas fa-shopping-cart"></i>
    <% if (typeof cart !== 'undefined' && cart.length > 0) { %>
      <span class="cart-count"><%= cart.reduce((sum, item) => sum + item.quantity, 0) %></span>
    <% } %>
  </a>
