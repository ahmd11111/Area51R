<%- include('partials/header') %>

<!-- Order Success Section -->
<section class="success-section">
  <div class="success-container">
    <div class="success-card">
      <div class="success-icon">
        <i class="fas fa-check-circle"></i>
      </div>
      <h1><%= t('orderSuccess.title') %></h1>
      <p><%= t('orderSuccess.desc') %></p>
      
      <div class="order-info">
        <div class="info-row">
          <span class="label"><%= t('orderSuccess.orderId') %>:</span>
          <span class="value"><%= orderId %></span>
        </div>
      </div>
      
      <div class="success-actions">
        <a href="/store" class="btn btn-primary">
          <i class="fas fa-store"></i> <%= t('orderSuccess.continueShopping') %>
        </a>
        <a href="/" class="btn btn-secondary">
          <i class="fas fa-home"></i> <%= t('orderSuccess.backToHome') %>
        </a>
      </div>
    </div>
  </div>
</section>

<%- include('partials/footer') %>